          "expr": "clamp((rate(opensips_GL_funnel_ingested{job=\"opensips\"}[2m]) - rate(opensips_GL_cdr_no_more_gws{job=\"opensips\"}[2m])) / clamp_min(rate(opensips_GL_funnel_ingested{job=\"opensips\"}[2m]), 0.001) * 100, 0, 100)",
