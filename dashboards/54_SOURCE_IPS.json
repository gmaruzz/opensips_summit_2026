      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(opensips_GL_kpi_abd_sum{job=\"opensips\"}[2m]) / clamp_min(rate(opensips_GL_kpi_abd_count{job=\"opensips\"}[2m]), 0.001)",
          "legendFormat": " ",
          "refId": "A",
          "editorMode": "code"
        }
      ],
      "timeFrom": "5m"
    },
