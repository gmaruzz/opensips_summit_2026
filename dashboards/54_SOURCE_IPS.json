    {
      "id": "prometheus",
      "name": "Prometheus",
      "type": "datasource",
      "version": "1.0.0"
    }
  ],
  "description": "Per-source-IP (FreeSWITCH node) business dashboard. Platform KPIs, per-IP drill-down with CPS, ASR, NER, CCR, ACD, ABD, PDD, MOS. Detail and quality timeseries include anomaly detection bands color-matched to lines.",
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "prod"
      ],
      "targetBlank": false,
      "title": "Prod Dashboards",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "LIVE",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "stat",
      "id": 2,
      "title": "CC Connected",
      "description": "Platform-wide connected (answered) calls. Always live.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#808080",
                "value": null
              }
            ]
          },
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value",
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "opensips_GL_cc_connected",
          "legendFormat": " ",
          "refId": "A",
          "editorMode": "code"
        }
      ],
      "timeFrom": "5m"
    },
    {
      "type": "stat",
      "id": 3,
      "title": "CPS Answered",
      "description": "Answered calls per second (2m rate). Always live.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#808080",
                "value": null
              }
            ]
          },
          "unit": "none",
          "noValue": "0",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value",
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(opensips_GL_cdr_success{job=\"opensips\"}[2m])",
          "legendFormat": " ",
          "refId": "A",
          "editorMode": "code"
        }
      ],
      "timeFrom": "5m"
    },
    {
